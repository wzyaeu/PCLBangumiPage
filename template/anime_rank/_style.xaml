<StackPanel.Resources>
    <Style x:Key="RankItemCard"
           TargetType="local:MyCard">
        <Setter Property="Margin"
                Value="0,5"/>
    </Style>
    <Style x:Key="RankItemGrid"
           TargetType="Grid">
        <Setter Property="Margin"
                Value="10"/>
    </Style>
    <Style x:Key="RankItemImage"
           TargetType="local:MyImage">
        <Setter Property="Height"
                Value="100"/>
        <Setter Property="Width"
                Value="100"/>
    </Style>
    <Style x:Key="RankItemMainStackPanel"
           TargetType="StackPanel">
        <Setter Property="Margin"
                Value="3"/>
    </Style>
    <Style x:Key="RankItemHeaderStackPanel"
           TargetType="StackPanel">
        <Setter Property="Orientation"
                Value="Horizontal"/>
        <Setter Property="Margin"
                Value="1"/>
    </Style>
    <Style x:Key="RankItemNoBorder"
           TargetType="Border">
        <Setter Property="VerticalAlignment"
                Value="Center"/>
        <Setter Property="Height"
                Value="25"/>
        <Setter Property="Background"
                Value="{DynamicResource ColorBrush3}"/>
        <Setter Property="CornerRadius"
                Value="7,0,0,7"/>
    </Style>
    <Style x:Key="RankItemNoText"
           TargetType="TextBlock">
        <Setter Property="VerticalAlignment"
                Value="Center"/>
        <Setter Property="HorizontalAlignment"
                Value="Center"/>
        <Setter Property="FontWeight"
                Value="Bold"/>
        <Setter Property="Margin"
                Value="10,2,10,2"/>
        <Setter Property="FontSize"
                Value="14"/>
        <Setter Property="Foreground"
                Value="{DynamicResource ColorBrush8}"/>
    </Style>
    <Style x:Key="RankItemRankBorder"
           TargetType="Border">
        <Setter Property="VerticalAlignment"
                Value="Center"/>
        <Setter Property="Height"
                Value="25"/>
        <Setter Property="Background"
                Value="#00b0ff"/>
        <Setter Property="CornerRadius"
                Value="0"/>
    </Style>
    <Style x:Key="RankItemRankStackPanel"
           TargetType="StackPanel">
        <Setter Property="Orientation"
                Value="Horizontal"/>
        <Setter Property="Margin"
                Value="4"/>
        <Setter Property="VerticalAlignment"
                Value="Bottom"/>
    </Style>
    <Style x:Key="RankItemRankLabel"
           TargetType="TextBlock">
        <Setter Property="VerticalAlignment"
                Value="Bottom"/>
        <Setter Property="FontSize"
                Value="11"/>
        <Setter Property="Foreground"
                Value="{DynamicResource ColorBrush8}"/>
    </Style>
    <Style x:Key="RankItemRankValue"
           TargetType="TextBlock">
        <Setter Property="FontSize"
                Value="16"/>
        <Setter Property="Margin"
                Value="2,-1,0,0"/>
        <Setter Property="Foreground"
                Value="{DynamicResource ColorBrush8}"/>
    </Style>
    <Style x:Key="RankItemScoreBorder"
           TargetType="Border">
        <Setter Property="VerticalAlignment"
                Value="Center"/>
        <Setter Property="Height"
                Value="25"/>
        <Setter Property="Background"
                Value="#ffb53d"/>
        <Setter Property="CornerRadius"
                Value="0,7,7,0"/>
    </Style>
    <Style x:Key="RankItemScoreStackPanel"
           TargetType="StackPanel">
        <Setter Property="Orientation"
                Value="Horizontal"/>
        <Setter Property="Margin"
                Value="4"/>
        <Setter Property="VerticalAlignment"
                Value="Bottom"/>
    </Style>
    <Style x:Key="RankItemScoreLabel"
           TargetType="TextBlock">
        <Setter Property="VerticalAlignment"
                Value="Bottom"/>
        <Setter Property="FontSize"
                Value="11"/>
        <Setter Property="Foreground"
                Value="{DynamicResource ColorBrush8}"/>
    </Style>
    <Style x:Key="RankItemScoreValue"
           TargetType="TextBlock">
        <Setter Property="FontSize"
                Value="16"/>
        <Setter Property="Margin"
                Value="2,-1,0,0"/>
        <Setter Property="Foreground"
                Value="{DynamicResource ColorBrush8}"/>
    </Style>
    <Style x:Key="RankItemTitleText"
           TargetType="TextBlock">
        <Setter Property="Margin"
                Value="4"/>
        <Setter Property="FontWeight"
                Value="Bold"/>
        <Setter Property="FontSize"
                Value="25"/>
        <Setter Property="Foreground"
                Value="{DynamicResource ColorBrush3}"/>
    </Style>
    <Style x:Key="RankItemTagsStackPanel"
           TargetType="StackPanel">
        <Setter Property="Margin"
                Value="1"/>
    </Style>
    <Style x:Key="RankItemTagsWrapPanel"
           TargetType="WrapPanel">
        <Setter Property="Height"
                Value="25"/>
    </Style>
    <Style x:Key="RankItemTagText"
           TargetType="TextBlock">
        <Setter Property="Margin"
                Value="2"/>
        <Setter Property="FontSize"
                Value="13"/>
    </Style>
</StackPanel.Resources>